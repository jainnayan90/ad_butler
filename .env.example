# Copy to .env and fill in values. Never commit .env.
#
# Docker Compose (prod-like):
#   DATABASE_URL should use service name "db" instead of "localhost"
#   RABBITMQ_URL should use service name "rabbitmq" instead of "localhost"
#   SESSION_SIGNING_SALT and SESSION_ENCRYPTION_SALT must also be set in your
#   shell (not just this file) — they are injected as BuildKit secrets at build time.

# --- Database ---
DATABASE_URL=ecto://postgres:postgres@localhost/ad_butler_dev
# For docker-compose.prod.yml use: ecto://postgres:postgres@db/ad_butler_prod
# Oban worker totals: default(10) + sync(20) + analytics(5) + audit(5) +
# fatigue_audit(5) + notifications(5) = 50. fatigue_audit + audit + sync run
# concurrently — set POOL_SIZE >= 60 in prod for headroom over web + cron.
POOL_SIZE=60

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672
# For docker-compose.prod.yml use: amqp://guest:guest@rabbitmq
RABBITMQ_POOL_SIZE=5

# --- Phoenix ---
SECRET_KEY_BASE=  # mix phx.gen.secret
PHX_HOST=localhost

# --- Session salts ---
# SESSION_SIGNING_SALT and SESSION_ENCRYPTION_SALT are compile-time only (endpoint.ex uses
# compile_env!). Inject at build time, not via runtime env. Rotation requires recompile + restart.
# LIVE_VIEW_SIGNING_SALT is safe at runtime (different config path).
# Generate with: mix phx.gen.secret 32
SESSION_SIGNING_SALT=
SESSION_ENCRYPTION_SALT=
LIVE_VIEW_SIGNING_SALT=

# --- Cloak encryption key (dev) ---
# Required — the app refuses to start in dev without this.
# Generate with: openssl rand -base64 32
CLOAK_KEY_DEV=

# --- Meta / Facebook App ---
META_APP_ID=
META_APP_SECRET=
META_OAUTH_CALLBACK_URL=http://localhost:4000/auth/meta/callback

# --- Prod Cloak key ---
# Generate with: 32 |> :crypto.strong_rand_bytes() |> Base.encode64()
# Must decode to exactly 32 bytes.
CLOAK_KEY=

# --- Email (production SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# --- Audit kill-switches ---
# true|false (default true) — disable creative-fatigue audits without redeploy.
# Read once at boot in config/runtime.exs; flip and restart workers to take effect.
FATIGUE_ENABLED=true

# --- LLM API keys (v0.3 chat + embeddings) ---
# ANTHROPIC_API_KEY powers chat (claude-sonnet-4-6 default, claude-haiku-4-5 fallback).
# OPENAI_API_KEY powers embeddings (text-embedding-3-small).
# Both are required in prod (System.fetch_env!). In dev they're optional — chat features
# stay disabled until set. ReqLLM resolves keys via app config → env var.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
